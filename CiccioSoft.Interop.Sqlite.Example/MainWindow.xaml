<Window x:Class="CiccioSoft.Interop.Sqlite.Example.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CiccioSoft.Interop.Sqlite.Example"
        mc:Ignorable="d"
        Title="Viewer"
        Height="410"
        Width="280" 
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Spazio per l'immagine 240x240 -->
            <RowDefinition Height="240" />
            <!-- Spazio per la TextBox -->
            <RowDefinition Height="Auto" />
            <!-- Spazio per i pulsanti Avanti/Dietro -->
            <RowDefinition Height="Auto" />
            <!-- Spazio per i pulsanti Ricarica/Chiudi -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 1. Contenitore Border per applicare lo sfondo grigio, contenente l'Image da 240x240 -->
        <Border Grid.Row="0" Width="240" Height="240" Background="#F0F0F0">
            <Image Name="VisualizzatoreImmagine" Stretch="UniformToFill"/>
        </Border>

        <!-- 2. TextBox per il testo descrittivo -->
        <TextBox Name="TestoDescrizione" Grid.Row="1" Margin="0,10,0,10" Height="25" VerticalContentAlignment="Center" IsReadOnly="True" Text="Testo iniziale..."/>

        <!-- 3. Pulsanti Avanti e Dietro -->
        <Grid Grid.Row="2" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Name="BtnDietro" Content="◀ Dietro" Grid.Column="0" Margin="0,0,5,0" Height="30" Click="BtnDietro_Click"/>
            <Button Name="BtnAvanti" Content="Avanti ▶" Grid.Column="1" Margin="5,0,0,0" Height="30" Click="BtnAvanti_Click"/>
        </Grid>

        <!-- 4. Pulsanti Ricarica e Chiudi -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Name="BtnRicarica" Content="🔄 Ricarica" Grid.Column="0" Margin="0,0,5,0" Height="30" Click="BtnRicarica_Click"/>
            <Button Name="BtnChiudi" Content="❌ Chiudi" Grid.Column="1" Margin="5,0,0,0" Height="30" Click="BtnChiudi_Click"/>
        </Grid>
    </Grid>
</Window>
