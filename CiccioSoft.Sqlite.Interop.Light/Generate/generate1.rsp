# =======================================================
# Configurazione per ClangSharpPInvokeGenerator
# Generazione binding SQLite nativi
# =======================================================

# File sorgente C/C++ di input
--file
sqlite3glue.h

# Forza ClangSharp a elaborare e generare binding anche per i file inclusi (#include)
# --traverse


# Output finale del codice generato
--output
../Native

# Namespace C# di destinazione
--namespace
CiccioSoft.Sqlite.Interop.Native

# Nome della DLL/libreria nativa inserito nei [DllImport] (es. sqlite3)
--libraryPath
sqlite3glue

# Nome della classe statica C# che conterrà i metodi P/Invoke generati
--methodClassName
Sqlite3GlueNative

# Linguaggio del codice sorgente di input da analizzare ('c' o 'c++')
--language
c

# Modificatore di accesso per i tipi e metodi C# generati (public/internal)
--with-access-specifier
Sqlite3Native=internal

# Esclude specifiche funzioni, struct o macro dalla generazione (Sintassi: nome)
# --exclude


# Rinomina un tipo nativo in un nome C# personalizzato (Sintassi: vecchio=nuovo
--remap
char=byte

# Passa opzioni di configurazione avanzate
--config
multi-file
generate-helper-types
generate-macro-bindings
latest-codegen
generate-disable-runtime-marshalling
